---
// Hero.astro – Full‑width hero with background image, title, quote, and CTA
import { Image } from "astro:assets";
import heroImage from "../assets/hero.jpg";
---

<section class="hero" aria-label="Hero">
  <a href="#" class="skip-link" data-i18n="skip_to_content">
    <img src={heroImage.src} alt="Hero image" />
  </a>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <h1 data-i18n="title_main">Palestinians are Your Eyes</h1>
    <p class="hero-quote" data-i18n="opening_quote"></p>
    
  </div>
</section>

<style>
  /* .btn-primary {
    font: bold;
    font-size: 2rem !important;
  } */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 4rem;
    overflow: hidden;
    background: var(--paper, #232222);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 1;
  }
  .hero a {
    font-family: "Source Serif Pro", Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
    opacity: 0.4;
    background-color: #d9cec4;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0.3;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 820px;
    padding: 1.5rem;
  }
  /* Title – keeps original style */
  h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2.8rem, 6vw + 1rem, 5.5rem);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--crimson, #561011);
    margin-bottom: 0.6em;
  }
  /* Quote – italic Playfair */
  .hero-quote {
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    color: var(--crimson, #232222);
    max-width: 640px;
    margin: 1.2rem auto 2rem;
    line-height: 1.65;
    mix-blend-mode: difference;
    background: rgba(255, 255, 255, 0.8);

  }
  /* CTA label – small uppercase Source Serif */

  

  
  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
      padding-bottom: 3rem;
    }

    .hero img {
      object-position: 60% 30%;
    }
    .hero-cta-block {
      gap: 0.6rem;
    }
    .hero img {
      object-position: 60% 30%;
    }
  }
  @media (max-width: 480px) {
    h1 {
      margin-bottom: 0.3em;
    }
    .hero img {
      object-position: 75% 30%;
    }
    .hero-quote {
      margin: 0.8rem auto 1.5rem;
    }
  }
  /* RTL adjustment */
  body[dir="rtl"] .hero-quote {
    border-right: none;
  }
</style>
