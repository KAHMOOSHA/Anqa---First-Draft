---
// Hero.astro – Full‑width hero with background image, title, quote, and CTA
import { Image } from "astro:assets";
import myImage from "../assets/anQa-03.png";
---

<section class="hero" aria-label="Hero">
  <div
    class="hero-bg"
    style="background-image: url({myImage.src});"
  >
  </div>
  <div class="hero-overlay"></div>
  <!-- <div class="hero-logo-area">
    <Image src={myImage} alt="Anqa Theater Logo" />
  </div> -->
  <div class="hero-content">
    <h1 data-i18n="title_main">Palestinians are Your Eyes</h1>
    <p class="hero-quote" data-i18n="opening_quote">
      "Palestinians are your eyes, your tattoo. Palestinians are your name, your
      dreams, your thoughts, and your scarf."
    </p>
    <div class="hero-cta-block">
      <span class="hero-cta-label" data-i18n="cta_eyebrow">
        Let's do theater together
      </span>
      <a href="#how-to-join" class="btn-primary" data-i18n="cta_primary">
        Host a Performance on October 15th — Join the Global Premiere
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 4rem;
    overflow: hidden;
    background: var(--paper, #f9f7f5);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
    opacity: 0.4;
    background-color: #d9cec4;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(249, 247, 245, 0.65) 0%,
      rgba(249, 247, 245, 0.2) 45%,
      rgba(249, 247, 245, 0) 70%,
      var(--paper, #f9f7f5) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 820px;
    padding: 1.5rem;
  }
  /* Title – keeps original style */
  h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2.8rem, 6vw + 1rem, 5.5rem);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--crimson, #561011);
    margin-bottom: 0.6em;
  }
  /* Quote – italic Playfair */
  .hero-quote {
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    color: var(--ink-soft, #2e2b2c);
    max-width: 640px;
    margin: 1.2rem auto 2rem;
    line-height: 1.65;
  }
  /* CTA label – small uppercase Source Serif */

  .hero-cta-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin-top: 1rem;
  }
  /* Button styling – uses global .btn-primary from global.css, but we keep a local fallback */
  .btn-primary {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  /* Responsive */
  @media (max-width: 700px) {
    .hero {
      min-height: 80vh;
      padding-bottom: 3rem;
    }
    .hero-cta-block {
      gap: 0.6rem;
    }
  }
  @media (max-width: 480px) {
    h1 {
      margin-bottom: 0.3em;
    }
    .hero-quote {
      margin: 0.8rem auto 1.5rem;
    }
  }
  /* RTL adjustment */
  body[dir="rtl"] .hero-quote {
    border-right: none;
  }
</style>
