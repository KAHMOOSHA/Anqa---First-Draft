      /* ─── i18n init ──────────────────────────────────────── */
      i18next.use(i18nextBrowserLanguageDetector).init(
        {
          resources,
          fallbackLng: "en",
          detection: {
            order: ["localStorage", "cookie", "navigator"],
            caches: ["localStorage"],
          },
          interpolation: { escapeValue: false },
        },
        (err, t) => {
          if (err) return;
          updateContent();
          applyDirection();
        },
      );

      function updateContent() {
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");
          const val = i18next.t(key, { defaultValue: key });
          if (val) el.innerHTML = val;
        });
      }

      function applyDirection() {
        document.body.setAttribute(
          "dir",
          i18next.language === "ar" ? "rtl" : "ltr",
        );
      }

      /* ─── Lang switcher ──────────────────────────────────── */
      const globeBtn = document.getElementById("globeButton");
      const langMenu = document.getElementById("langMenu");

      globeBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        langMenu.classList.toggle("show");
      });
      document.addEventListener("click", (e) => {
        if (!globeBtn.contains(e.target) && !langMenu.contains(e.target))
          langMenu.classList.remove("show");
      });
      document.querySelectorAll(".lang-option").forEach((btn) => {
        btn.addEventListener("click", () => {
          i18next.changeLanguage(btn.dataset.lang, () => {
            updateContent();
            applyDirection();
            langMenu.classList.remove("show");
          });
        });
      });
    </script>
  </body>
</html>
