---
// index.astro — Palestinians are Your Eyes | Anqa Theater
import "../styles/global.css";
import { Image } from "astro:assets";
import myImage from "../assets/anQa-03.png";

// Import the three new components
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import CountdownTimer from "../components/CountdownTimer.astro";
import FollowInstagram from "../components/FollowInstagram.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <title>Palestinians are Your Eyes | Anqa Theater</title>
    <link rel="icon" href="/favicon.svg" />
    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,400;1,600&display=swap"
      rel="stylesheet"
    />

    <!-- i18next -->
    <script src="https://unpkg.com/i18next@23.10.0/dist/umd/i18next.min.js"
    ></script>
    <script
      src="https://unpkg.com/i18next-browser-languagedetector@7.2.0/dist/umd/i18nextBrowserLanguageDetector.min.js"
    ></script>
  </head>

  <body>
    <div class="wrap">
      <!-- Navbar component (fixed, with logo and language switcher) -->
      <Navbar />

      <!-- Hero component (full‑width with background image and CTA) -->
      <Hero />
      <div class="hero-cta-block">
        <p class="hero-cta-label" data-i18n="cta_eyebrow">
          Let's do theater together
        </p>
        <a
          style="text-align: center; margin:  0.5rem 0"
          href="#how-to-join"
          class="btn-primary"
          data-i18n="cta_primary"
        >
          Host a Performance on October 15th — Join the Global Premiere
        </a>
      </div>

      <!-- Countdown Timer component -->
      <CountdownTimer />

      <>
        <!-- PROJECT INTRO -->
        <section id="project-intro" class="content-section reveal">
          <h2 data-i18n="project_title">Palestinians Are Your Eyes</h2>
          <p data-i18n="project_desc">
            <em>Palestinian Are Your Eyes</em> is a theatrical reading composed of
            six unpublished texts written by Gazan authors from the Italian-Palestinian
            theatre company Anqa, established in 2023 under the impulse of Progetto
            REC.Palestina.
          </p>
        </section>
        <hr class="section-rule" />

        <!-- WHY OCTOBER 15TH -->
        <section id="why-oct15" class="content-section reveal">
          <h2 data-i18n="why_title">Why October 15th?</h2>
          <p data-i18n="why_text">
            October 15 is not just a date on the calendar, but an open wound in
            the history of our company. On that day in 2023, while rehearsals
            were supposed to begin in Milan for an Italian tour that never took
            place, news arrived of the death of Abraham Saidam, a young
            performer killed by Israeli bombings.
          </p>
          <p data-i18n="why_text2">
            To honor his memory and transform grief into cultural resistance, on
            October 15, 2026, <em>Palestinian Are Your Eyes</em> will be staged—a
            distributed theatrical reading that will simultaneously involve theaters,
            associations, bookstores, and schools throughout Italy, Europe, Jordan
            and Gaza. A chorus of voices to break the silence and tear down the fences
            of indifference.
          </p>
        </section>
        <hr class="section-rule" />

        <!-- HOW TO JOIN (with email CTA button) -->
        <section id="how-to-join" class="content-section reveal">
          <h2 data-i18n="participate_title">How to Join: October 15, 2026</h2>
          <p data-i18n="participate_intro">
            Participating in the distributed staging project on October 15,
            2026, is simple. The initiative aims to unite diverse voices into a
            single, great collective narrative that will cross Italy and the
            world.
          </p>
          <div class="application-box">
            <h3 data-i18n="app_process_title">Application Process</h3>
            <p data-i18n="app_process_intro">
              To confirm your participation, send an email to <strong
                >progettorec.palestina@gmail.com</strong
              > specifying:
            </p>
            <ul class="application-list">
              <li data-i18n="app_item1">
                <strong>Identity of the Organization</strong> — Name, website, social
                channels.
              </li>
              <li data-i18n="app_item2">
                <strong>Territory</strong> — Province and municipality where you intend
                to organize the event.
              </li>
              <li data-i18n="app_item3">
                <strong>Logistical Details</strong> — The venue (theater, club, park,
                etc.).
              </li>
              <li data-i18n="app_item4">
                <strong>Cast and Crew</strong> — Names of performers, technicians,
                and directors involved.
              </li>
            </ul>
            <p class="application-note" data-i18n="app_note">
              All technical details can be sent later — the important thing is
              to get in touch first.
            </p>
          </div>
          <div style="text-align:center; margin: 1rem 0;">
            <a
              href="mailto:progettorec.palestina@gmail.com"
              class="btn-email"
              data-i18n="email_cta"
              >✉ Write to Us — progettorec.palestina@gmail.com</a
            >
            <!-- or at info@anqa.group -->
            <br />
            <br />
            <a
              href="mailto:info@anqa.group"
              class="btn-email"
              data-i18n="email_cta2">info@anqa.group</a
            >
          </div>
          <p
            style="font-size:0.9rem;  margin-top:1rem;"
            data-i18n="synergy_note"
          >
            Should multiple applications arrive for the same area, priority will
            be given to the first request received. The spirit of this project
            is collaborative — we will foster synergies among different entities
            in the same territory.
          </p>
        </section>
        <hr class="section-rule" />

        <!-- WHO THIS PROJECT IS FOR -->
        <section id="who-for" class="content-section reveal">
          <h2 data-i18n="who_title">Who This Project Is For</h2>
          <p data-i18n="who_text">
            The project is aimed at a wide network of entities: theatrical
            institutions, associations, schools, bookstores, collectives, clubs,
            and more. It has been designed to ensure maximum production
            sustainability, requiring minimal technical setups — the staging can
            be achieved even through a simple reading of the texts.
          </p>
        </section>
        <hr class="section-rule" />

        <!-- ABOUT THE PROJECT -->
        <section id="about-project" class="content-section reveal">
          <h2 data-i18n="about_project_title">About the Project</h2>
          <h3 data-i18n="op_guidelines_title">Operational Guidelines</h3>
          <p data-i18n="op_guidelines_text">
            Each participating organization operates with full organizational
            and artistic autonomy — free to choose the event location (theaters,
            bookstores, unconventional spaces), cast (professionals or
            non-professionals), and stage design (music, video, lighting).
          </p>
          <h3 data-i18n="kit_title">Provided Resources — Digital Kit</h3>
          <p data-i18n="kit_text">
            Progetto REC will provide participating entities with the complete
            script — six unpublished stories distributed under a Creative
            Commons license — and optional original audio recordings by the
            Gazan authors, usable as a soundscape.
          </p>
          <h3 data-i18n="docu_title">The Documentary Film</h3>
          <p data-i18n="docu_text">
            All events will receive visibility through our official channels.
            Organizations that document their evening on video can send us the
            footage: recordings will merge into a collective documentary project
            dedicated to this choral narrative.
          </p>
          <h3 data-i18n="solidarity_title">Solidarity Initiatives</h3>
          <p data-i18n="solidarity_text">
            Participating entities, where possible, can donate a portion of
            proceeds to Progetto REC.Palestina — partly to support the Anqa
            company and future projects, partly for the humanitarian
            interventions of <strong>Emergenza Gaza</strong>. This contribution
            is entirely optional.
          </p>
        </section>
        <hr class="section-rule" />

        <!-- ABOUT US -->
        <section id="about-us" class="content-section reveal">
          <h2 data-i18n="about_us_title">About Us</h2>
          <h3 data-i18n="anqa_title">Anqa: The Story of the Company</h3>
          <p data-i18n="anqa_text1">
            Between late 2022 and early 2023, a group of Italian operators from <strong
              >Progetto REC.Palestina</strong
            > traveled to the Gaza Strip to found the <strong
              >Anqa Theater Company</strong
            > alongside local youth. Together, they created the production <em
              >All That's Left to Me</em
            > (paraphrasing Ghassan Kanafani's <em>All That's Left to You</em>).
          </p>
          <p data-i18n="anqa_text2">
            The play premiered at Ayyam Al Masrah (Theatre Day Productions) in
            Gaza City on January 7, 2023. Inspired by the Odyssey, it served as
            a metaphor for an infinite journey — the painful narrative of
            Palestine, a land where refugees cannot return and from which the
            youth cannot leave.
          </p>

          <h3 data-i18n="dream_title">A Dream Shattered: The Canceled Tour</h3>
          <p data-i18n="dream_text1">
            After a triumphant debut in Gaza City, covered by international
            outlets including Al Jazeera, the project was set for a month-long
            tour in Italy. Stages in Milan, Genoa, Siena, Rome, and Bologna were
            ready to welcome these young actors.
          </p>
          <p data-i18n="dream_text2">
            Everything was ready. Visas obtained, contracts signed, flights
            booked — they were scheduled to arrive on October 10, 2023. But
            after October 7, everything changed. In a matter of hours, the dream
            became a nightmare.
          </p>
          <p data-i18n="dream_text3">
            On October 15, 2023 — the day rehearsals were to begin in Milan — we
            received the devastating news: Abraham Saidam, who played Odysseus,
            had been killed. Abraham was posthumously awarded the "President of
            the Jury" prize at the 4th Ivo Chiesa International Awards by Gad
            Lerner.
          </p>

          <h3 data-i18n="newproject_title">
            Palestinians are Your Eyes — The New Project
          </h3>
          <p data-i18n="newproject_text">
            The reading gathers six texts written by Gazan authors of the Anqa
            company: heterogeneous narratives blending raw realism and allegory,
            offering a pluralistic testimony of life in the Gaza Strip. For
            those living through the horror, writing becomes <em>poiesis</em> — a
            space of freedom where pain is transfigured into living words.
          </p>
          <p data-i18n="conclusion_text" style="font-style:italic; ">
            The project, whose title pays homage to the poet Mahmoud Darwish (<em
              >Lover from Palestine</em
            >), aspires to become a collective memory and a bridge between
            distant worlds.
          </p>
        </section>
        <hr class="section-rule" />

        <!-- STORIES (list, no cards) -->
        <hr class="section-rule" />

        <!-- AUTHORS & CREDITS -->
        <section id="authors-credits" class="content-section reveal">
          <h2 data-i18n="authors_label">Authors & Their Stories</h2>
          <ul class="author-list">
            <li>
              <span class="author-name">Ibrahim Alhelou</span><span
                class="author-works"
                data-i18n="author1_works">TheMother Poem · The Pawn</span
              >
            </li>
            <li>
              <span class="author-name">Dalal Elswerky</span><span
                class="author-works"
                data-i18n="author2_works"
                >Under an Olive-Green Sky · A Pillar in the Concrete</span
              >
            </li>
            <li>
              <span class="author-name">Fatma Yousef</span><span
                class="author-works"
                data-i18n="author3_works">First Lesson</span
              >
            </li>
            <li>
              <span class="author-name">Ala'a Sbaih</span><span
                class="author-works"
                data-i18n="author4_works">Anqa Maghrib</span
              >
            </li>
          </ul>

          <p
            style="margin: 2rem 0 0.5rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; font-size:0.75rem;"
            data-i18n="tutors_label"
          >
            Tutors
          </p>
          <ul class="tutor-list">
            <li data-i18n="tutor1">
              Simon Gusman <em style="opacity:0.6;">(Coordinator)</em>
            </li>
            <li>Giulia Borghi</li>
            <li>Stefania Buraschi</li>
            <li>Donato Loiacono</li>
            <li>Mattia Majerna</li>
            <li>Mario Valenti</li>
          </ul>

          <p
            style="margin: 2rem 0 0.5rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; font-size:0.75rem;"
            data-i18n="crew_label"
          >
            Production
          </p>
          <div class="crew-strip">
            <span>Karam Jad</span><span>Marco Stefani</span><span
              >Filippo Barone</span
            >
          </div>

          <p
            style="margin: 2rem 0 0.5rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; font-size:0.75rem;"
            data-i18n="promoted_label"
          >
            Promoted by
          </p>
          <div class="crew-strip">
            <span>Progetto REC.Palestina</span><span>APS Scighera</span><span
              >ACS ONG</span
            ><span>VIK CENTER</span><span>PEM – HABITAT TEATRALI</span><span
              >AUDREY ANPI</span
            >
          </div>
        </section>
        <hr />
        <FollowInstagram />
      </>

      <footer class="reveal">
        <span data-i18n="footer_text"
          >Palestinians are Your Eyes — For Our Dreamer © Anqa Theater Company</span
        >
      </footer>
    </div>

